function isTeraboxUrl(url) {
  try {
    const p = new URL(url);
    return TERABOX_DOMAINS.some(d => p.hostname.includes(d));
  } catch { return false; }
}

function extractSurl(url) {
  try {
    const p = new URL(url);
    const m = p.pathname.match(/\/s\/([a-zA-Z0-9_-]+)/);
    if (m) return m[1];
    return p.searchParams.get("surl") || null;
  } catch { return null; }
}

