// ── UTILS ────────────────────────────────────────────────────────────────────

function jsonResp(data, status = 200) {
  return new Response(JSON.stringify(data, null, 2), {
    status,
    headers: { "Content-Type": "application/json", ...corsHeaders },
  });
}

function formatBytes(bytes) {
  if (!bytes || bytes == 0) return "0 B";
  bytes = parseInt(bytes);
  const units = ["B", "KB", "MB", "GB", "TB"];
  const i = Math.floor(Math.log(bytes) / Math.log(1024));
  return (bytes / Math.pow(1024, i)).toFixed(2) + " " + units[i];
}

function formatDuration(seconds) {
  if (!seconds) return null;
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  const s = Math.floor(seconds % 60);
  if (h > 0) return `${h}:${String(m).padStart(2,"0")}:${String(s).padStart(2,"0")}`;
  return `${m}:${String(s).padStart(2,"0")}`;
}

function detectQuality(item) {
  if (item.video_info?.clarification) return item.video_info.clarification;
  const size = Number(item.size || 0);
  if (size > 8e9)   return "4K";
  if (size > 3e9)   return "1080p";
  if (size > 1e9)   return "720p";
  if (size > 400e6) return "480p";
  if (size > 0)     return "360p";
  return null;
}

function parseNetscapeCookies(txt) {
  if (!txt) return {};
  const cookies = {};
  for (const line of txt.split("\n")) {
    const t = line.trim();
    if (!t || t.startsWith("#")) continue;
    const parts = t.split("\t");
    if (parts.length >= 7) cookies[parts[5].trim()] = parts[6].trim();
  }
  return cookies;
}

function getNdus(env) {
  if (env.NDUS_COOKIE) return env.NDUS_COOKIE.trim();
  if (env.TERABOX_COOKIES_TXT) return parseNetscapeCookies(env.TERABOX_COOKIES_TXT)["ndus"] || "";
  return "";
}

// Build proxy URL — direct playable in any player
function buildProxyUrl(workerOrigin, targetUrl) {
  return `${workerOrigin}/proxy?url=${encodeURIComponent(targetUrl)}`;
}

// =============================================
// SUBTITLE M3U8 CONVERTER
// =============================================

function buildSubtitleM3U8(subtitleInfoArray, workerOrigin) {
  if (!subtitleInfoArray?.length) return null;
  let m3u8 = "#EXTM3U\n";
  for (const sub of subtitleInfoArray) {
    const lang     = sub.lan       || sub.language || sub.lang || "und";
    const langName = sub.lan_name  || sub.language_name || lang.toUpperCase();
    const rawUrl   = sub.url       || sub.subtitle_url || "";
    if (!rawUrl) continue;
    const proxied = buildProxyUrl(workerOrigin, rawUrl);
    m3u8 += `#EXT-X-MEDIA:TYPE=SUBTITLES,GROUP-ID="subs",LANGUAGE="${lang}",NAME="${langName}",URI="${proxied}"\n`;
  }
  return m3u8;
}

function buildSubtitleResponse(subtitleInfoArray, workerOrigin) {
  if (!subtitleInfoArray?.length) return null;
  return {
    format: "M3U8",
    count:  subtitleInfoArray.length,
    m3u8_playlist: buildSubtitleM3U8(subtitleInfoArray, workerOrigin),
    languages: subtitleInfoArray.map(s => ({
      language:      s.lan       || s.language || s.lang || "und",
      language_name: s.lan_name  || s.language_name || "Unknown",
      url:           buildProxyUrl(workerOrigin, s.url || s.subtitle_url || ""),
      raw_url:       s.url || s.subtitle_url || null,
    })),
  };
}

