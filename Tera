async function fetchHLSUrls(item, shareInfo, cookieStr, workerOrigin) {
  const result = { fast_stream_url: null, stream_url: null, subtitle_url: null };

  if (!shareInfo.uk || !shareInfo.shareid || !shareInfo.sign || !shareInfo.timestamp) {
    return result;
  }

  // ─── 1) HLS URLs via /share/streaming endpoint ─────────────────────────
  const qualityTypes = {
    "360p":  "M3U8_AUTO_360",
    "480p":  "M3U8_AUTO_480",
    "720p":  "M3U8_AUTO_720",
    "1080p": "M3U8_AUTO_1080",
    "4K":    "M3U8_AUTO_2160",
  };

  const hlsRaw = {};
  const hlsProxied = {};
  for (const [quality, type] of Object.entries(qualityTypes)) {
    const s = new URL("https://dm.terabox.app/share/streaming");
    s.searchParams.append("app_id",     "250528");
    s.searchParams.append("clienttype", "0");
    s.searchParams.append("channel",    "dubox");
    s.searchParams.append("web",        "1");
    s.searchParams.append("uk",         shareInfo.uk);
    s.searchParams.append("shareid",    shareInfo.shareid);
    s.searchParams.append("fid",        item.fs_id);
    s.searchParams.append("timestamp",  shareInfo.timestamp);
    s.searchParams.append("sign",       shareInfo.sign);
    s.searchParams.append("type",       type);
    s.searchParams.append("vip",        "0");
    const raw = s.toString();
    hlsRaw[quality] = raw;
    hlsProxied[quality] = buildProxyUrl(workerOrigin, raw);
  }
  result.fast_stream_url = hlsProxied;

  // ─── 2) Media Meta — for subtitles + normal mp4 URL ────────────────────
  try {
    const metaUrl = new URL("https://dm.terabox.app/share/mediameta");
    metaUrl.searchParams.append("app_id",     "250528");
    metaUrl.searchParams.append("clienttype", "0");
    metaUrl.searchParams.append("channel",    "dubox");
    metaUrl.searchParams.append("web",        "1");
    metaUrl.searchParams.append("uk",         shareInfo.uk);
    metaUrl.searchParams.append("shareid",    shareInfo.shareid);
    metaUrl.searchParams.append("fid_list",   `[${item.fs_id}]`);
    metaUrl.searchParams.append("timestamp",  shareInfo.timestamp);
    metaUrl.searchParams.append("sign",       shareInfo.sign);

    const resp = await fetch(metaUrl.toString(), {
      headers: {
        "User-Agent": UA_DESKTOP,
        "Accept": "application/json, text/plain, */*",
        "Cookie": cookieStr,
        "Referer": "https://dm.terabox.app/",
        "Origin": "https://dm.terabox.app",
        "X-Requested-With": "XMLHttpRequest",
      },
    });

    if (resp.ok) {
      const meta = await resp.json();
      const entry = meta.list?.[0] || meta;

      result.stream_url =
        entry.video_info?.normal_video_url ||
        entry.video_info?.video_url        ||
        entry.normal_video_url             ||
        entry.dlink                        ||
        result.stream_url;

      const subInfo =
        entry.subtitle_info ||
        entry.video_info?.subtitle_info ||
        meta.subtitle_info ||
        [];

      if (Array.isArray(subInfo) && subInfo.length) {
        result.subtitle_url = buildSubtitleResponse(subInfo, workerOrigin);
      }
    }
  } catch { /* HLS already set */ }

  return result;
}

// =============================================
// PROXY ENDPOINT — Injects cookie so M3U8/segments
// play directly in any player (VLC/MX/hls.js)
// =============================================

async function handleProxy(request, env) {
  const url = new URL(request.url);
  const target = url.searchParams.get("url");
  if (!target) return new Response("Missing url param", { status: 400, headers: corsHeaders });

  let targetUrl;
  try { targetUrl = new URL(target); }
  catch { return new Response("Invalid url", { status: 400, headers: corsHeaders }); }

  // Only allow Terabox-related hosts
  const allowedHostFragment = [
    "terabox", "1024tera", "mirrobox", "nephobox", "freeterabox",
    "4funbox", "tibibox", "tobybox", "momerybox", "jobebox", "gibibox",
    "boxlinks", "teradlbox", "teradownload", "dubox",
  ];
  if (!allowedHostFragment.some(h => targetUrl.hostname.includes(h))) {
    return new Response("Host not allowed", { status: 403, headers: corsHeaders });
  }

  const ndus = getNdus(env);
  const headers = {
    "User-Agent": UA_DESKTOP,
    "Accept": "*/*",
    "Referer": "https://dm.terabox.app/",
    "Origin":  "https://dm.terabox.app",
  };
  if (ndus) headers["Cookie"] = `ndus=${ndus}`;

  // Forward Range header (for video seeking)
  const range = request.headers.get("Range");
  if (range) headers["Range"] = range;

  const upstream = await fetch(targetUrl.toString(), {
    method: request.method,
    headers,
    redirect: "follow",
  });

  const ct = (upstream.headers.get("Content-Type") || "").toLowerCase();
  const isM3U8 =
    ct.includes("mpegurl") ||
    ct.includes("vnd.apple") ||
    targetUrl.pathname.endsWith(".m3u8") ||
    targetUrl.searchParams.get("type")?.startsWith("M3U8");

  // Build worker origin for rewriting
  const workerOrigin = `${url.protocol}//${url.host}`;

  if (isM3U8) {
    let body = await upstream.text();
    body = rewriteM3U8(body, targetUrl, workerOrigin);

    const respHeaders = new Headers({
      "Content-Type": "application/vnd.apple.mpegurl",
      "Cache-Control": "no-cache",
      ...corsHeaders,
    });
    return new Response(body, { status: upstream.status, headers: respHeaders });
  }

  // For binary (.ts segments, mp4, subtitle, etc.) — stream-through
  const respHeaders = new Headers(upstream.headers);
  for (const [k, v] of Object.entries(corsHeaders)) respHeaders.set(k, v);
  respHeaders.delete("Set-Cookie");
  respHeaders.delete("Content-Security-Policy");

  return new Response(upstream.body, {
    status: upstream.status,
    headers: respHeaders,
  });
}

// Rewrite all URLs inside .m3u8 so they also go through proxy
function rewriteM3U8(text, baseUrl, workerOrigin) {
  const lines = text.split(/\r?\n/);
  const out = [];
  for (let line of lines) {
    const trimmed = line.trim();

    if (!trimmed) { out.push(line); continue; }

    // Lines starting with # but containing URI="..."
    if (trimmed.startsWith("#")) {
      line = line.replace(/URI="([^"]+)"/g, (_, u) => {
        const abs = resolveUrl(u, baseUrl);
        return `URI="${workerOrigin}/proxy?url=${encodeURIComponent(abs)}"`;
      });
      out.push(line);
      continue;
    }

    // Plain URL line (segment or sub-playlist)
    const abs = resolveUrl(trimmed, baseUrl);
    out.push(`${workerOrigin}/proxy?url=${encodeURIComponent(abs)}`);
  }
  return out.join("\n");
}

function resolveUrl(maybeRelative, baseUrl) {
  try { return new URL(maybeRelative, baseUrl).toString(); }
  catch { return maybeRelative; }
}

