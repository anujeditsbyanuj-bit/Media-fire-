async function fetchTeraboxData(surl, ndus, workerOrigin) {
  let short_url = surl;
  if (surl.startsWith("1")) short_url = surl.substring(1);
  const cookieStr = `ndus=${ndus}`;

  // Step 1: jsToken
  const firstResp = await fetch(`https://dm.terabox.app/sharing/link?surl=${surl}`, {
    headers: { "User-Agent": UA_DESKTOP, "Cookie": cookieStr },
  });
  const text = await firstResp.text();
  const match = text.match(/fn%28%22(.*?)%22%29/);
  if (!match) return { error: "jsToken extract nahi hua. Cookie expire ho gayi hogi." };
  const jsToken = match[1];

  // Step 2: Share list
  const apiUrl = new URL("https://dm.terabox.app/share/list");
  apiUrl.searchParams.append("app_id", "250528");
  apiUrl.searchParams.append("jsToken", jsToken);
  apiUrl.searchParams.append("site_referer", "https://www.terabox.app/");
  apiUrl.searchParams.append("shorturl", short_url);
  apiUrl.searchParams.append("root", "1");

  const apiResp = await fetch(apiUrl.toString(), {
    headers: {
      "Host": "dm.terabox.app",
      "User-Agent": UA_DESKTOP,
      "Accept": "application/json, text/plain, */*",
      "Accept-Language": "en-US,en;q=0.9",
      "X-Requested-With": "XMLHttpRequest",
      "Referer": `https://dm.terabox.app/sharing/link?surl=${short_url}&clearCache=1`,
      "Content-Type": "application/x-www-form-urlencoded",
      "Origin": "https://dm.terabox.app",
      "Cookie": cookieStr,
    },
  });

  const result = await apiResp.json();
  if (!result.list?.length) {
    return { error: "Files nahi mile. Link expired ya invalid hai.", raw: result };
  }

  const shareInfo = {
    shareid:   result.shareid,
    uk:        result.uk,
    sign:      result.sign,
    timestamp: result.timestamp,
  };

  const rawFolders = result.list.filter(i => i.isdir === "1");
  const rawFiles   = result.list.filter(i => i.isdir !== "1");

  let allFolderFiles = [];
  for (const folder of rawFolders) {
    const sub = await fetchFolderFiles(folder.path, short_url, jsToken, shareInfo, cookieStr);
    allFolderFiles = allFolderFiles.concat(sub);
  }

  const allRawFiles = [...rawFiles, ...allFolderFiles];
  const files = await Promise.all(
    allRawFiles.map(item => processFile(item, shareInfo, cookieStr, workerOrigin))
  );

  const folders = rawFolders.map(i => ({
    "📁 Name":      i.server_filename,
    "📋 Type":      "folder",
    "📍 Full Path": i.path || i.server_filename,
  }));

  return {
    "✅ Status":   "Success",
    "📂 Folders":  folders,
    "📄 Files":    files,
    "📊 Summary": {
      "📂 Total Folders": folders.length,
      "📄 Total Files":   files.length,
      "🔢 Total Items":   folders.length + files.length,
    },
  };
}

async function fetchFolderFiles(folderPath, short_url, jsToken, shareInfo, cookieStr) {
  try {
    const url = new URL("https://dm.terabox.app/share/list");
    url.searchParams.append("app_id", "250528");
    url.searchParams.append("jsToken", jsToken);
    url.searchParams.append("shorturl", short_url);
    url.searchParams.append("dir", folderPath);
    url.searchParams.append("num", "100");

    const resp = await fetch(url.toString(), {
      headers: {
        "User-Agent": UA_DESKTOP,
        "Accept": "application/json, text/plain, */*",
        "Cookie": cookieStr,
        "Referer": `https://dm.terabox.app/sharing/link?surl=${short_url}`,
      },
    });

    const data = await resp.json();
    const items = data.list || [];
    let result = [];
    for (const item of items) {
      if (item.isdir === "1") {
        const sub = await fetchFolderFiles(item.path, short_url, jsToken, shareInfo, cookieStr);
        result = result.concat(sub);
      } else {
        result.push(item);
      }
    }
    return result;
  } catch { return []; }
}

async function processFile(item, shareInfo, cookieStr, workerOrigin) {
  const isVideo = String(item.category) === "1";
  const isAudio = String(item.category) === "2";

  let fast_stream_url = null;
  let stream_url      = item.dlink || null;
  let subtitle_url    = null;

  if (isVideo && shareInfo.shareid && shareInfo.uk) {
    const hls = await fetchHLSUrls(item, shareInfo, cookieStr, workerOrigin);
    fast_stream_url = hls.fast_stream_url;
    stream_url      = hls.stream_url || stream_url;
    subtitle_url    = hls.subtitle_url;
  }

  return {
    "📁 Name":                  item.server_filename,
    "📋 Type":                  isVideo ? "video" : isAudio ? "audio" : "file",
    "📍 Full Path":             item.path || item.server_filename,
    "✏️ Size":                  formatBytes(item.size),
    "📐 Size Bytes":            Number(item.size || 0),
    "🎬 Duration":              item.duration ? formatDuration(Number(item.duration)) : null,
    "📺 Quality":               detectQuality(item),
    "🖼 Thumbnails":            item.thumbs || null,
    "🔗 Direct Download Link":  item.dlink || null,
    "▶️ Stream URL":            stream_url,
    "⚡ Fast Stream URL (HLS)": fast_stream_url,
    "📝 Subtitle (M3U8)":       subtitle_url,
    "🆔 fs_id":                 String(item.fs_id || ""),
  };
}

